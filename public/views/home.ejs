<!-- Hero Section -->
<section id="home" class="hero-section">
    <div class="container">
        <div class="row align-items-center min-vh-100">
            <div class="col-lg-6 hero-content">
                <h1 class="hero-title animate-on-scroll">
                    <span class="gradient-text">PRRP</span> FiveM PvP
                </h1>
                <p class="hero-subtitle animate-on-scroll">
                    En iyi PvP deneyimi için doğru adres. Rekabetçi oyun modları, 
                    ödüllü turnuvalar ve daha fazlası sizleri bekliyor.
                </p>
                <div class="hero-buttons animate-on-scroll">
                    <a href="/stats" class="btn btn-primary btn-lg me-3">
                        <i class="fas fa-chart-bar me-2"></i>İstatistikler
                    </a>
                    <a href="/shop" class="btn btn-outline-light btn-lg">
                        <i class="fas fa-shopping-cart me-2"></i>Mağaza
                    </a>
                </div>
            </div>
            <div class="col-lg-6 hero-image animate-on-scroll">
                <img src="../../assets/hero-image.png" alt="PRRP Gameplay" class="img-fluid rounded-3 shadow-lg">
            </div>
        </div>
    </div>
</section>

<!-- Özellikler Section -->
<section id="features" class="features-section">
    <div class="container">
        <h2 class="section-title text-center mb-5">Sunucu Özellikleri</h2>
        <div class="row g-4">
            <div class="col-md-4 feature-card animate-on-scroll">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <i class="fas fa-trophy feature-icon"></i>
                        <h3 class="card-title">Turnuvalar</h3>
                        <p class="card-text">Düzenli turnuvalar ve ödüllü yarışmalar ile rekabetçi oyun deneyimi.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 feature-card animate-on-scroll">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <i class="fas fa-store feature-icon"></i>
                        <h3 class="card-title">Özel Mağaza</h3>
                        <p class="card-text">Benzersiz silahlar, araçlar ve özel eşyalar için kapsamlı mağaza sistemi.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 feature-card animate-on-scroll">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <i class="fas fa-users feature-icon"></i>
                        <h3 class="card-title">Topluluk</h3>
                        <p class="card-text">Aktif ve destekleyici bir oyuncu topluluğu ile keyifli oyun deneyimi.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- İstatistikler Section -->
<section id="stats" class="stats-section">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-3 stat-card animate-on-scroll">
                <div class="stat-item text-center">
                    <i class="fas fa-users stat-icon"></i>
                    <h3 class="stat-number" data-count="1000">0</h3>
                    <p class="stat-label">Aktif Oyuncu</p>
                </div>
            </div>
            <div class="col-md-3 stat-card animate-on-scroll">
                <div class="stat-item text-center">
                    <i class="fas fa-trophy stat-icon"></i>
                    <h3 class="stat-number" data-count="50">0</h3>
                    <p class="stat-label">Turnuva</p>
                </div>
            </div>
            <div class="col-md-3 stat-card animate-on-scroll">
                <div class="stat-item text-center">
                    <i class="fas fa-star stat-icon"></i>
                    <h3 class="stat-number" data-count="4.8">0</h3>
                    <p class="stat-label">Ortalama Puan</p>
                </div>
            </div>
            <div class="col-md-3 stat-card animate-on-scroll">
                <div class="stat-item text-center">
                    <i class="fas fa-clock stat-icon"></i>
                    <h3 class="stat-number" data-count="24">0</h3>
                    <p class="stat-label">Saat Aktif</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section id="cta" class="cta-section">
